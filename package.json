{
  "name": "@ialeks/zod-decorator",
  "version": "0.2.0",
  "description": "TypeScript decorators for Zod schema validation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "preversion": "pnpm test",
    "version": "node scripts/sync-version.js && pnpm build && git add -A",
    "postversion": "git push && git push --tags"
  },
  "keywords": [
    "zod",
    "decorator",
    "validation",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^3.0.5",
    "zod": "^3.24.1"
  },
  "packageManager": "pnpm@9.15.0"
}
